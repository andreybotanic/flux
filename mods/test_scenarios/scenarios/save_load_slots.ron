Scenario(
    id: "test_scenarios:scenario/save_load_slots",
    steps: [
        Log("save load started"),
        LoadGame("slot_a"),
        AssertTick(3),
        PauseSimulation(delay_ms: 120),
        SetCameraPivot(x: 10, y: 10),
        SetCameraZoom(0.04),
        TakeScreenshot("slot_a_world.png"),
        OpenMenu("base:menu/main"),
        AssertUiExists("base:widget/main_menu/load_slot_b"),
        TakeScreenshot("main_menu_after_slot_a.png"),
        Click("base:widget/main_menu/load_slot_b"),
        AssertTick(4),
        PauseSimulation(delay_ms: 120),
        SetCameraPivot(x: 20, y: 10),
        SetCameraZoom(0.04),
        TakeScreenshot("slot_b_world.png"),
        OpenMenu("base:menu/main"),
        AssertUiExists("base:widget/main_menu/load_slot_a"),
        TakeScreenshot("main_menu_after_slot_b.png"),
        Log("save load finished"),
    ],
)
