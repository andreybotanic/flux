# Normalize text files.
* text=auto eol=lf

# Rust/source/config/docs
*.rs text eol=lf
*.toml text eol=lf
*.ron text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ktx2 binary
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
*.zip binary
*.bin binary
*.save binary
